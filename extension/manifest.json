{
  "manifest_version": 3,
  "name": "datad Tableau Extractor",
  "version": "0.1.0",
  "description": "Extract Tableau data from the active tab using browser session credentials.",
  "permissions": ["tabs", "activeTab", "scripting"],
  "host_permissions": ["https://*.tableau.com/*", "https://*.tableauusercontent.com/*"],
  "action": {
    "default_title": "Extract Tableau CSV",
    "default_popup": "popup.html"
  }
}
